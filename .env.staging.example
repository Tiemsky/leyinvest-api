# ============================================
# ENVIRONMENT: STAGING
# Branch: develop
# Domain: staging-api.leyinvest.com
# ============================================

# Application
APP_NAME="LeyInvest Staging"
APP_ENV=staging
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=true
APP_URL=https://staging-api.leyinvest.com

# Database PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres_staging
DB_PORT=5432
DB_DATABASE=leyinvest_staging
DB_USERNAME=leyinvest_staging
DB_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_STAGING

# Redis
REDIS_HOST=redis_staging
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache & Session & Queue
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Mail (Resend)
MAIL_MAILER=resend
RESEND_API_KEY=re_VOTRE_CLE_RESEND_STAGING
MAIL_FROM_ADDRESS=staging@leyinvest.com
MAIL_FROM_NAME="LeyInvest Staging"

# Frontend
FRONTEND_URL=https://staging.leyinvest.com

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Session
SESSION_LIFETIME=120
SESSION_DOMAIN=.leyinvest.com

# CORS
SANCTUM_STATEFUL_DOMAINS=staging.leyinvest.com,staging-api.leyinvest.com

# Broadcast
BROADCAST_DRIVER=log

# Filesystem
FILESYSTEM_DISK=local

# ============================================
# VARIABLES SPECIFIQUES STAGING
# ============================================
# Rate limiting moins strict pour testing
THROTTLE_RATE_LIMIT=1000
